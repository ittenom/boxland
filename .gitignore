# Build artifacts
/server/boxland
/server/boxland.exe
/boxland.exe
/bin/
/server/dist/
/web/dist/
/web/node_modules/
/web/**/node_modules/
/web/.vite/
/web/**/.vite/

# Generated code is committed (Go-style "checked-in generated source",
# same convention as protobuf-generated files). Regenerate with
# `boxland setup` after editing schemas, queries, or templ sources;
# the tripwire test in internal/setup catches drift.
#
# - server/internal/proto/                 ← from schemas/*.fbs (flatc)
# - server/internal/persistence/hotpath/   ← from server/queries/*.sql (sqlc)
# - server/views/*_templ.go                ← from server/views/*.templ (templ)
# - web/src/net/proto/                     ← from schemas/*.fbs (flatc, ts side)

# Staged web bundle (regenerated by `just design` / `just _stage-web` /
# the production Docker image's multi-stage copy). The .gitkeep
# placeholder lets the //go:embed all:web directive resolve even when
# the bundle hasn't been built yet.
/server/static/web/*
!/server/static/web/.gitkeep

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Environment
.env
.env.local
*.log

# Coverage
coverage.out
coverage.html

# Go vendoring (we don't use it in this repo, but keep the rule for any
# accidental `go mod vendor`). Scoped to /server/vendor/ so it never
# shadows server/static/vendor/, which holds checked-in third-party JS.
/server/vendor/
/web/vendor/

# Docker
.docker-data/

# Probe / scratch scripts
_*.ps1
_*.txt
_*.html
_*.bat
_*.pid
_*.err
server/migrate.out
server/migrate.err
server/server.log
server/server.err.log

# Superpowers brainstorming session files (mockups, server state)
.superpowers/
