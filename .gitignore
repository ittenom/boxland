# Build artifacts
/server/boxland
/server/boxland.exe
/server/dist/
/web/dist/
/web/node_modules/
/web/**/node_modules/
/web/.vite/
/web/**/.vite/

# Generated FlatBuffers code (regenerated via `just gen-fb`)
/server/internal/proto/
/web/src/net/proto/

# Generated sqlc code (regenerated via `just gen-sqlc`)
/server/internal/persistence/hotpath/

# Generated Templ code (regenerated via `just gen-templ`)
/server/views/*_templ.go

# Synced fonts (canonical copy lives in /shared/fonts/)
/server/static/fonts/

# Staged web bundle (regenerated by `just design` / `just _stage-web` /
# the production Docker image's multi-stage copy). The .gitkeep
# placeholder lets the //go:embed all:web directive resolve even when
# the bundle hasn't been built yet.
/server/static/web/*
!/server/static/web/.gitkeep

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Environment
.env
.env.local
*.log

# Coverage
coverage.out
coverage.html

# Go
vendor/

# Docker
.docker-data/

# Probe / scratch scripts
_*.ps1
_*.txt
server/migrate.out
server/migrate.err
server/server.log
server/server.err.log
