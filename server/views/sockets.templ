package views

import (
	"fmt"

	"boxland/server/internal/entities"
)

// SocketsListProps drives /design/sockets.
type SocketsListProps struct {
	Layout LayoutProps
	Items  []entities.EdgeSocketType

	// UsageByID maps socket id → number of tile-edge assignments
	// referencing it. Built by the handler so the delete confirm
	// surfaces real impact ("3 tile assignments will lose this edge")
	// instead of a vague "become null" warning.
	UsageByID map[int64]int
}

templ SocketsList(p SocketsListProps) {
	@Layout(p.Layout) {
		<div class="bx-work__strip">
			<span class="bx-work__chip">
				<span class="bx-dot bx-dot--socket"></span>
				<strong>{ formatIntPad(len(p.Items)) }</strong> sockets
			</span>
			<span class="bx-work__chip bx-work__chip--muted">
				tag tile edges so the procedural Mapmaker knows what fits where
			</span>
		</div>

		<div class="bx-work__body bx-stack" style="max-width: 720px;">
			<header class="bx-row bx-row--apart">
				<div>
					<h1 data-copy-slot="sockets.title">Edge sockets</h1>
					<p class="bx-muted bx-small" data-copy-slot="sockets.lede">
						Project-wide tags that connect tiles in procedural maps.
						Assign sockets to a tile-kind entity in its detail editor.
					</p>
				</div>
			</header>

			<section class="bx-panel">
				<h2 class="bx-panel__title" data-copy-slot="sockets.new">Add a socket</h2>
				<form
					hx-post="/design/sockets"
					hx-target="#sockets-grid"
					hx-swap="outerHTML"
					class="bx-row"
				>
					<input class="bx-input" name="name" placeholder="e.g. field" required maxlength="64" style="max-width: 240px;"/>
					<input class="bx-input" name="color" type="color" value="#FFDD4A" style="max-width: 64px; padding: 2px;" aria-label="color"/>
					<button type="submit" class="bx-btn bx-btn--primary" data-copy-slot="sockets.new.submit">Add</button>
				</form>
			</section>

			@SocketsGrid(p)
		</div>
	}
}

templ SocketsGrid(p SocketsListProps) {
	if len(p.Items) == 0 {
		<div id="sockets-grid" class="bx-panel" style="text-align:center;">
			<p class="bx-muted" data-copy-slot="sockets.empty">No sockets yet.</p>
		</div>
	} else {
		<table id="sockets-grid" class="bx-table">
			<thead>
				<tr><th>Name</th><th>Color</th><th>Used by</th><th></th></tr>
			</thead>
			<tbody>
				for _, s := range p.Items {
					<tr>
						<td>{ s.Name }</td>
						<td>
							<span class="bx-color-swatch" style={ fmt.Sprintf("background:%s;", colorHex(s.Color)) }></span>
							<code class="bx-mono bx-small bx-muted">{ colorHex(s.Color) }</code>
						</td>
						<td class="bx-small bx-muted">{ socketUsageLabel(s.ID, p.UsageByID) }</td>
						<td>
							<button
								type="button"
								class="bx-btn bx-btn--ghost bx-btn--small bx-btn--danger"
								hx-delete={ fmt.Sprintf("/design/sockets/%d", s.ID) }
								hx-target="#sockets-grid"
								hx-swap="outerHTML"
								hx-confirm={ socketDeleteConfirm(s.ID, p.UsageByID) }
								data-copy-slot="sockets.delete"
							>Delete</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	}
}

// socketUsageLabel renders the per-row "used by" cell. "—" when usage
// data isn't loaded; "0 (orphan)" when zero; "N edge(s)" otherwise.
func socketUsageLabel(id int64, usage map[int64]int) string {
	if usage == nil {
		return "—"
	}
	n := usage[id]
	if n == 0 {
		return "0 (orphan)"
	}
	if n == 1 {
		return "1 edge"
	}
	return fmt.Sprintf("%d edges", n)
}

// socketDeleteConfirm builds the per-socket delete confirm with the
// real assignment-edge count so designers know exactly what they're
// nulling out. ON DELETE SET NULL preserves the entity-type rows;
// only the four nullable socket columns lose their reference.
func socketDeleteConfirm(id int64, usage map[int64]int) string {
	if usage == nil {
		return "Delete this socket? Tile assignments referencing it become null."
	}
	n := usage[id]
	if n == 0 {
		return "Delete this socket? Nothing references it."
	}
	if n == 1 {
		return "Delete this socket? 1 tile-edge assignment loses this edge (the entity stays; the edge becomes null)."
	}
	return fmt.Sprintf("Delete this socket? %d tile-edge assignments lose this edge (the entities stay; the edges become null).", n)
}

// colorHex turns a 0xRRGGBBAA int64 into a "#rrggbb" CSS color.
func colorHex(rgba int64) string {
	r := (rgba >> 24) & 0xff
	g := (rgba >> 16) & 0xff
	b := (rgba >> 8) & 0xff
	return fmt.Sprintf("#%02x%02x%02x", r, g, b)
}
