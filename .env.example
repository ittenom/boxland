# Boxland — environment configuration template.
#
# Copy this to `.env` (gitignored) for local development. Production values
# are injected by Railway / your container host. Every variable used by the
# server appears here; CI runs `just lint-env` to verify no orphans.

# ---------- Server ----------
BOXLAND_ENV=dev                          # dev | staging | prod
BOXLAND_HTTP_ADDR=:8080                  # Go server listen address
BOXLAND_LOG_FORMAT=pretty                # pretty | json (json in prod)
BOXLAND_LOG_LEVEL=info                   # debug | info | warn | error

# ---------- Postgres ----------
# Dev container exposes Postgres on host port 5433 to avoid conflicts with a
# locally installed Postgres on the standard 5432.
DATABASE_URL=postgres://boxland:boxland_dev@localhost:5433/boxland?sslmode=disable

# ---------- Redis ----------
# Dev container exposes Redis on host port 6380 (vs standard 6379) for the
# same reason.
REDIS_URL=redis://localhost:6380/0

# ---------- Object storage (S3-compatible) ----------
# Local dev points at MinIO from docker-compose. Prod overrides with R2/S3 creds.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=boxland-assets
S3_ACCESS_KEY_ID=boxland
S3_SECRET_ACCESS_KEY=boxland_dev_secret
S3_USE_PATH_STYLE=true                   # true for MinIO, false for AWS S3 / R2
S3_PUBLIC_BASE_URL=http://localhost:9000/boxland-assets
                                          # CDN base URL for content-addressed asset paths

# ---------- SMTP (email verification, password reset) ----------
SMTP_HOST=localhost
SMTP_PORT=1025                           # Mailpit dev SMTP; prod uses real SMTP
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@boxland.local

# ---------- Auth secrets ----------
# Generate locally with: openssl rand -base64 64
SESSION_COOKIE_SECRET=CHANGE_ME_local_dev_only_do_not_ship_this
JWT_SIGNING_SECRET=CHANGE_ME_local_dev_only_do_not_ship_this
DESIGNER_WS_TICKET_SECRET=CHANGE_ME_local_dev_only_do_not_ship_this

# ---------- OAuth providers (optional; feature-flagged) ----------
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_ENABLED=false
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=
OAUTH_DISCORD_ENABLED=false
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=

# ---------- Game tuning (rarely changed) ----------
TICK_HZ=10                               # authoritative simulation rate
WAL_FLUSH_TICKS=20                       # mutation batch size before Postgres flush
AOI_RADIUS_TILES=24                      # default subscription radius
RECONNECT_GAP_TICK_LIMIT=600             # reconnect within this many ticks → diff replay; otherwise full Snapshot
